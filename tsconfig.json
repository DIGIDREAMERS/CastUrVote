{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "firebase/app": ["./node_modules/@firebase/app/dist/app-public.d.ts"],
      "firebase/auth": ["./node_modules/@firebase/auth/dist/auth-public.d.ts"],
      "firebase/firestore": ["./node_modules/@firebase/firestore/dist/index.d.ts"],
      "firebase/storage": ["./node_modules/@firebase/storage/dist/storage-public.d.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
